def homePage(*gin.Context c) (
    boolean authenticated = c.MustGet("authenticated").toStr() == "true"
    object user = c.MustGet("user")

    c.HTML(200, "home.html", {
        ActivePage: "home",
        Authenticated: authenticated,
        User: user,
        UserId: c.MustGet("userId")
    })
)

def themesPage(*gin.Context c) (
    boolean authenticated = c.MustGet("authenticated").toStr() == "true"
    object user = c.MustGet("user")
    string sortBy = c.DefaultQuery("sort", "newest")
    string platformFilter = c.DefaultQuery("platform", "")

    auto result = listThemes(sortBy)

    auto themes = []
    auto userMap = {}
    auto modsData = loadMods()
    object mods = modsData.mods.assert(object)

    if result.ok (
        themes = result.themes.toArray()

        array authorIds = []
        for i themes.len (
            string author = themes[i].author.toStr()
            if !authorIds.contains(author) and author != "" (
                authorIds.append(author)
            )
        )

        userMap = loadUsersByIds(authorIds)
    )

    if platformFilter != "" (
        array filteredThemes = []
        for i themes.len (
            object item = themes[i]
            if item.platform.toStr() == platformFilter (
                filteredThemes.append(item)
            )
        )
        themes = filteredThemes
    )

    c.HTML(200, "index.html", {
        ActivePage: "themes",
        Themes: themes,
        Users: userMap,
        Mods: mods,
        Authenticated: authenticated,
        User: user,
        UserId: c.MustGet("userId"),
        SortBy: sortBy,
        PlatformFilter: platformFilter
    })
)

def authPage(*gin.Context c) (
    boolean authenticated = c.MustGet("authenticated").toStr() == "true"

    if authenticated (
        c.Redirect(302, "/")
        return
    )

    c.HTML(200, "auth.html", {
        ActivePage: "auth"
    })
)

