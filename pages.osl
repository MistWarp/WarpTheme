def uploadSuccessPage(*gin.Context c) (
    object user = c.MustGet("user")
    string userId = c.MustGet("userId").toStr()
    boolean authenticated = c.MustGet("authenticated").toStr() == "true"
    string countStr = c.DefaultQuery("count", "1")
    number count = countStr.toNum()
    int countInt = count.toInt()

    c.HTML(200, "upload-success.html", {
        ActivePage: "upload",
        User: user,
        Authenticated: authenticated,
        UserId: userId,
        ThemeCount: countInt
    })
)

def settingsPage(*gin.Context c) (
	object user = c.MustGet("user")
	string userId = c.MustGet("userId").toStr()
	boolean authenticated = c.MustGet("authenticated").toStr() == "true"

	c.HTML(200, "settings.html", {
		ActivePage: "settings",
		User: user,
		Authenticated: authenticated,
		UserId: userId
	})
)

def logout(*gin.Context c) (
    string token = getCookie(c, "auth_token")
    if token != "" (
        deleteSession(token)
    )
    clearAuthCookie(c)
    c.Redirect(302, "/")
)
