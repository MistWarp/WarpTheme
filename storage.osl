def ensureDirectories() boolean (
    boolean result = fs.MkdirAll(usersDir)
    result = result and fs.MkdirAll(sessionsDir)
    result = result and fs.MkdirAll(ratingsDir)
    result = result and fs.MkdirAll(downloadsDir)
    result = result and fs.MkdirAll(themesDir)
    return result
)

def migrateUsers() boolean (
    string oldFile = "data/users.json"
    if !fs.Exists(oldFile) (
        return true
    )
    
    auto result = readFile(oldFile)
    if !result.ok (
        return false
    )
    
    object usersData = result.data.assert(object)
    object users = usersData.users
    
    array userIds = users.getKeys().toArray()
    
    for i userIds.len (
        string userId = userIds[i].toStr()
        object user = users[userId]
        
        string path = usersDir ++ userId ++ ".json"
        if !fs.Exists(path) (
            writeFile(path, user)
        )
    )
    
    string backupPath = oldFile ++ ".backup"
    fs.Rename(oldFile, backupPath)
    
    return true
)

def migrateSessions() boolean (
    string oldFile = "data/sessions.json"
    if !fs.Exists(oldFile) (
        return true
    )
    
    auto result = readFile(oldFile)
    if !result.ok (
        return false
    )
    
    object sessionsData = result.data.assert(object)
    object sessions = sessionsData.sessions
    
    array sessionIds = sessions.getKeys().toArray()
    
    for i sessionIds.len (
        string sessionId = sessionIds[i].toStr()
        object session = sessions[sessionId]
        
        string path = sessionsDir ++ sessionId ++ ".json"
        if !fs.Exists(path) (
            writeFile(path, session)
        )
    )
    
    string backupPath = oldFile ++ ".backup"
    fs.Rename(oldFile, backupPath)
    
    return true
)

def migrateRatings() boolean (
    string oldFile = "data/ratings.json"
    if !fs.Exists(oldFile) (
        return true
    )
    
    auto result = readFile(oldFile)
    if !result.ok (
        return false
    )
    
    object ratingsData = result.data.assert(object)
    object ratings = ratingsData.ratings
    
    array themeUUIDs = ratings.getKeys().toArray()
    
    for i themeUUIDs.len (
        string uuid = themeUUIDs[i].toStr()
        object rating = ratings[uuid]
        
        string path = ratingsDir ++ uuid ++ ".json"
        if !fs.Exists(path) (
            writeFile(path, rating)
        )
    )
    
    string backupPath = oldFile ++ ".backup"
    fs.Rename(oldFile, backupPath)
    
