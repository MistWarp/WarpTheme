)

def migrateDownloads() boolean (
    string oldFile = "data/downloads.json"
    if !fs.Exists(oldFile) (
        return true
    )
    
    auto result = readFile(oldFile)
    if !result.ok (
        return false
    )
    
    object downloadsData = result.data.assert(object)
    object downloads = downloadsData.downloads
    
    array themeUUIDs = downloads.getKeys().toArray()
    
    for i themeUUIDs.len (
        string uuid = themeUUIDs[i].toStr()
        object download = downloads[uuid]
        
        string path = downloadsDir ++ uuid ++ ".json"
        if !fs.Exists(path) (
            writeFile(path, download)
        )
    )
    
    string backupPath = oldFile ++ ".backup"
    fs.Rename(oldFile, backupPath)
    
